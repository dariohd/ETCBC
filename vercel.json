{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://bullechatbot.vercel.app; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://formsubmit.co https://bullechatbot.vercel.app; font-src 'self' data:; frame-src 'self' https://www.openstreetmap.org; base-uri 'self'; object-src 'none'; frame-ancestors 'self' https://*.vercel.app https://bulletonsite.com https://www.bulletonsite.com https://dariohd.github.io http://localhost:3000 http://localhost:5174"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/bulle/:path*",
      "destination": "https://bullechatbot.vercel.app/api/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/charpente.html",
      "destination": "/charpente",
      "permanent": true
    },
    {
      "source": "/amenagement-combles.html",
      "destination": "/amenagement-combles",
      "permanent": true
    },
    {
      "source": "/construction-bois.html",
      "destination": "/construction-bois",
      "permanent": true
    },
    {
      "source": "/couverture.html",
      "destination": "/couverture",
      "permanent": true
    },
    {
      "source": "/menuiseries.html",
      "destination": "/menuiseries",
      "permanent": true
    },
    {
      "source": "/realisations.html",
      "destination": "/realisations",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/mentions-legales.html",
      "destination": "/mentions-legales",
      "permanent": true
    }
  ]
}
